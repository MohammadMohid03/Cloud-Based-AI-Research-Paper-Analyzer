# =============================================================================
# AI-Powered Research Paper Analyzer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
# =============================================================================

# ── Database Configuration ───────────────────────────────────────────────────
DB_HOST=research-paper-db.cbu8okuo02tp.eu-north-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CloudProject1
DB_NAME=research_paper_db

# ── Server Configuration ────────────────────────────────────────────────────
SERVER_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── JWT Authentication ──────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random string in production!
JWT_SECRET=your-secret-key-change-in-production

# ── AI Provider Configuration ──────────────────────────────────────────────
# Options: "mock" (default, no AI calls), "bedrock" (AWS Bedrock)
AI_PROVIDER=mock

# ── Storage Provider Configuration ──────────────────────────────────────────
# Options: "local" (default, stores files on disk), "s3" (AWS S3)
STORAGE_PROVIDER=local

# ── AWS Configuration (required only when AI_PROVIDER=bedrock or STORAGE_PROVIDER=s3) ─
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── S3 Configuration (required only when STORAGE_PROVIDER=s3) ───────────────
S3_BUCKET=research-paper-analyzer-cloud-project

# ── Amazon Bedrock Configuration (required only when AI_PROVIDER=bedrock) ───
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
