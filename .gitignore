# =============================================================================
# AI-Powered Research Paper Analyzer — .gitignore
# =============================================================================

# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
backend/.env
frontend/.env
node_modules/
frontend/node_modules/
dist/
frontend/dist/

# ── Go ───────────────────────────────────────────────────────────────────────
backend/tmp/
backend/vendor/
backend/uploads/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.html

# ── Node.js / React ─────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.next/
frontend/.cache/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── IDE & Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Uploads & Generated ─────────────────────────────────────────────────────
uploads/
*.pdf
!docs/*.pdf

# ── Terraform / IaC ─────────────────────────────────────────────────────────
*.tfstate
*.tfstate.*
.terraform/
*.tfvars

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
