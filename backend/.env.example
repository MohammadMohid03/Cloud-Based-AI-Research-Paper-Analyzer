# =============================================================================
# AI-Powered Research Paper Analyzer - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the HTTP server listens on
PORT=8080

# Gin mode: "debug" for development, "release" for production
GIN_MODE=debug

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# PostgreSQL connection parameters
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=research_paper_analyzer
DB_SSLMODE=disable

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
# Secret key used to sign JWT tokens - USE A STRONG RANDOM STRING IN PRODUCTION
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiration in hours (default: 72 hours)
JWT_EXPIRY_HOURS=72

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Which AI provider to use: "mock" for local testing, "bedrock" for AWS Bedrock
AI_PROVIDER=mock

# -----------------------------------------------------------------------------
# AWS Configuration (required when AI_PROVIDER=bedrock or STORAGE_PROVIDER=s3)
# -----------------------------------------------------------------------------
# AWS region for Bedrock and S3
AWS_REGION=us-east-1

# AWS credentials (leave blank to use IAM roles or environment credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS Bedrock model ID (Claude 3 Sonnet recommended)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# Where to store uploaded PDFs: "local" for local filesystem, "s3" for AWS S3
STORAGE_PROVIDER=local

# S3 bucket name (required when STORAGE_PROVIDER=s3)
S3_BUCKET_NAME=research-paper-analyzer-uploads

# Local upload directory (used when STORAGE_PROVIDER=local)
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Seed Data
# -----------------------------------------------------------------------------
# Whether to seed the database with demo data on startup
SEED_DATA=true
